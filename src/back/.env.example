# Copy to .env and adjust. All optional (defaults shown).

# Database (default: SQLite in data/events.db)
# DATABASE_URL=sqlite:///./data/events.db
# DATABASE_URL=postgresql://user:pass@localhost/hidden_leaders

# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Port for run.py / uvicorn
# PORT=8000

# CORS: * or comma-separated origins (e.g. https://myapp.com)
# CORS_ORIGINS=*
